# ============================================================
# 企业知识库 — 环境变量配置模板
# 复制为 .env 后填写真实值，切勿提交 .env 到版本库
# ============================================================

# ---- LLM / 嵌入 ------------------------------------------------
# 阿里云 DashScope（必填，用于 qwen-turbo 问答 & 嵌入）
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MinerU PDF 解析（可选，使用 Precision API 时填写）
MINERU_API_KEY=

# Jina Reranker（可选，use_jina_reranker=True 时填写）
JINA_API_KEY=

# ---- 后端 JWT --------------------------------------------------
# 生产环境请替换为随机强密钥：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# ---- 管理员账号（首次启动自动创建）-------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ---- CORS（逗号分隔，开发环境默认已包含 5173/3000）---------------
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
